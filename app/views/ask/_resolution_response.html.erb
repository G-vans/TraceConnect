<div class="ask-msg-system">
  <div style="font-size: 0.75rem; color: var(--text-tertiary); margin-bottom: 0.375rem;">
    Resolution rate for <%= description %>
  </div>
  <div style="display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: 0.5rem;">
    <span style="font-size: 1.5rem; font-weight: 600; color: var(--status-green);"><%= rate %>%</span>
  </div>
  <div style="font-size: 0.75rem; color: var(--text-secondary);">
    <%= resolved %> resolved out of <%= total %> total
  </div>
  <div class="progress-track" style="margin-top: 0.5rem;">
    <div class="progress-fill progress-green" style="width: <%= rate %>%;"></div>
  </div>
</div>
