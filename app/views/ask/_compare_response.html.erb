<div class="ask-msg-system">
  <div style="font-size: 0.75rem; color: var(--text-tertiary); margin-bottom: 0.75rem;">
    Comparing <%= branch_data.map { |b| b[:name] }.join(" vs ") %> — <%= filter_label %> conversations
  </div>

  <% branch_data.each_with_index do |branch, idx| %>
    <div style="<%= 'margin-top: 0.75rem; padding-top: 0.75rem; border-top: 1px solid var(--border-subtle);' if idx > 0 %>">
      <div style="font-size: 0.8125rem; font-weight: 600; margin-bottom: 0.375rem;"><%= branch[:name] %></div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.25rem; font-size: 0.75rem;">
        <div style="color: var(--text-secondary);">Total</div>
        <div style="font-weight: 500;"><%= branch[:total] %></div>

        <div style="color: var(--text-secondary);">Open / In Progress / Resolved</div>
        <div>
          <span style="color: var(--status-yellow);"><%= branch[:open] %></span> /
          <span style="color: var(--status-blue);"><%= branch[:in_progress] %></span> /
          <span style="color: var(--status-green);"><%= branch[:resolved] %></span>
        </div>

        <div style="color: var(--text-secondary);">Resolution Rate</div>
        <div style="font-weight: 500; color: var(--status-green);"><%= branch[:resolution_rate] %>%</div>

        <div style="color: var(--text-secondary);">Avg Resolution Time</div>
        <div style="font-weight: 500;">
          <% if branch[:avg_resolution_hours] > 0 %>
            <%= branch[:avg_resolution_hours] < 24 ? "#{branch[:avg_resolution_hours]}h" : "#{(branch[:avg_resolution_hours] / 24.0).round(1)}d" %>
          <% else %>
            —
          <% end %>
        </div>

        <% if branch[:top_agent] %>
          <div style="color: var(--text-secondary);">Top Agent</div>
          <div style="font-weight: 500;"><%= branch[:top_agent][:name] %> (<%= branch[:top_agent][:count] %> resolved)</div>
        <% end %>

        <% if branch[:avg_sentiment] %>
          <div style="color: var(--text-secondary);">Avg Sentiment</div>
          <div style="font-weight: 500; color: <%= branch[:avg_sentiment] > 0.3 ? 'var(--status-green)' : branch[:avg_sentiment] < -0.3 ? 'var(--status-red)' : 'var(--status-yellow)' %>;">
            <%= branch[:avg_sentiment] %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if branch_data.size == 2 %>
    <% faster = branch_data.min_by { |b| b[:avg_resolution_hours] > 0 ? b[:avg_resolution_hours] : Float::INFINITY } %>
    <% if faster[:avg_resolution_hours] > 0 %>
      <div style="margin-top: 0.75rem; padding: 0.5rem 0.625rem; background: var(--status-green-bg); border-radius: 6px; font-size: 0.75rem; color: var(--status-green);">
        <strong><%= faster[:name] %></strong> resolves faster (avg <%= faster[:avg_resolution_hours] < 24 ? "#{faster[:avg_resolution_hours]}h" : "#{(faster[:avg_resolution_hours] / 24.0).round(1)}d" %>)
      </div>
    <% end %>
  <% end %>
</div>
