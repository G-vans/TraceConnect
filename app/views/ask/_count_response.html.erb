<div class="ask-msg-system">
  <div style="font-size: 0.75rem; color: var(--text-tertiary); margin-bottom: 0.375rem;">
    Counting <%= description %>
  </div>
  <div style="display: flex; align-items: baseline; gap: 0.5rem;">
    <span style="font-size: 1.5rem; font-weight: 600;"><%= count %></span>
    <span style="font-size: 0.8125rem; color: var(--text-secondary);">conversation<%= count == 1 ? '' : 's' %></span>
  </div>
</div>
