<div class="ask-msg-system">
  <div style="font-size: 0.75rem; color: var(--text-tertiary); margin-bottom: 0.375rem;">
    Sentiment for <%= description %>
  </div>
  <% if avg_score %>
    <div style="font-size: 1.25rem; font-weight: 600; margin-bottom: 0.5rem;
                color: <%= avg_score > 0.3 ? 'var(--status-green)' : avg_score < -0.3 ? 'var(--status-red)' : 'var(--status-yellow)' %>;">
      Score: <%= avg_score %>
    </div>
  <% end %>
  <div style="display: flex; gap: 0.375rem; flex-wrap: wrap;">
    <% label_counts.each do |label, count| %>
      <% color_class = label == "positive" ? "badge-resolved" : label == "negative" ? "badge-high" : "badge-medium" %>
      <span class="badge <%= color_class %>"><%= label&.humanize %>: <%= count %></span>
    <% end %>
  </div>
  <div style="font-size: 0.6875rem; color: var(--text-tertiary); margin-top: 0.375rem;">
    Based on <%= total %> conversation<%= total == 1 ? '' : 's' %>
  </div>
</div>
