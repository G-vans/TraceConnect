<% content_for(:title) { "Radar Dashboard — TraceConnect" } %>

<div style="margin-bottom: 1.5rem;">
  <h1 style="font-size: 1.25rem; font-weight: 600; color: var(--text-primary);">Radar Dashboard</h1>
  <p class="section-subtitle" style="margin-top: 0.25rem;">HQ command center — see all branches at a glance</p>
</div>

<!-- Pattern Alerts -->
<% if @pattern_alerts.any? %>
  <div class="alert alert-warning" style="margin-bottom: 1.5rem;">
    <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
      <span style="font-size: 1rem;">⚠</span>
      <span style="font-size: 0.8125rem; font-weight: 600; color: var(--status-red);">Pattern Alert</span>
    </div>
    <p class="text-secondary" style="font-size: 0.75rem; margin-bottom: 0.75rem;">Same issue detected across multiple branches this week</p>
    <% @pattern_alerts.each do |alert| %>
      <div class="card-padded" style="margin-bottom: 0.5rem; display: flex; align-items: center; justify-content: space-between;">
        <div>
          <span style="font-weight: 500;"><%= alert[:category]&.humanize %></span>
          <span class="text-secondary" style="margin-left: 0.5rem; font-size: 0.75rem;">
            <%= alert[:total] %> complaints across <%= alert[:branches].keys.join(", ") %>
          </span>
        </div>
        <div style="display: flex; gap: 0.375rem;">
          <% alert[:branches].each do |branch, count| %>
            <span class="badge badge-high"><%= branch %>: <%= count %></span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<!-- Branch Cards -->
<div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1.5rem;">
  <% @branches.each do |branch| %>
    <div class="card-padded">
      <div style="display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 1rem;">
        <div>
          <h3 style="font-size: 0.9375rem; font-weight: 600;"><%= branch[:name] %></h3>
          <p class="text-secondary" style="font-size: 0.75rem;"><%= branch[:country] %> · <%= branch[:law] %></p>
        </div>
        <%= consent_badge(branch[:consent_status]) %>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem;">
        <div class="stat-block">
          <div class="stat-value"><%= branch[:open_issues] %></div>
          <div class="stat-label">Open</div>
        </div>
        <div class="stat-block">
          <div class="stat-value"><%= branch[:in_progress] %></div>
          <div class="stat-label">In Progress</div>
        </div>
        <div class="stat-block">
          <div class="stat-value"><%= branch[:resolved_total] %></div>
          <div class="stat-label">Resolved</div>
        </div>
        <div class="stat-block">
          <div class="stat-value"><%= format_hours(branch[:avg_resolution_hours]) %></div>
          <div class="stat-label">Avg Resolution</div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<!-- Quick Stats -->
<div class="card-padded">
  <h2 class="section-title">This Week at a Glance</h2>
  <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; text-align: center;">
    <div>
      <div style="font-size: 1.75rem; font-weight: 600;"><%= @quick_stats[:total_conversations] %></div>
      <div class="text-secondary" style="font-size: 0.75rem;">Total Conversations</div>
    </div>
    <div>
      <div style="font-size: 1.75rem; font-weight: 600; color: var(--status-green);"><%= @quick_stats[:resolution_rate] %>%</div>
      <div class="text-secondary" style="font-size: 0.75rem;">Resolution Rate</div>
    </div>
    <div>
      <% if @quick_stats[:top_performer] %>
        <div style="font-size: 1.75rem; font-weight: 600;"><%= @quick_stats[:top_performer][:name] %></div>
        <div class="text-secondary" style="font-size: 0.75rem;">Top Performer (<%= @quick_stats[:top_performer][:resolved_count] %> resolved)</div>
      <% else %>
        <div style="font-size: 1.75rem; font-weight: 600;" class="text-tertiary">—</div>
        <div class="text-secondary" style="font-size: 0.75rem;">Top Performer</div>
      <% end %>
    </div>
  </div>
</div>
