<% content_for(:title) { "Conversations — TraceConnect" } %>

<div style="margin-bottom: 1.5rem;">
  <h1 style="font-size: 1.25rem; font-weight: 600;">Conversations</h1>
  <p class="section-subtitle" style="margin-top: 0.25rem;">Search and trace any conversation across all branches</p>
</div>

<!-- Filters -->
<div class="card-padded" style="margin-bottom: 1rem;">
  <%= form_with url: conversations_path, method: :get, style: "display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: flex-end;", data: { turbo_frame: "conversations_list" } do |f| %>
    <div>
      <label style="display: block; font-size: 0.6875rem; font-weight: 500; color: var(--text-tertiary); margin-bottom: 0.25rem;">Branch</label>
      <%= f.select :branch, options_for_select([["All Branches", ""], "Nairobi", "Lagos", "New York"], params[:branch]), {}, class: "filter-select" %>
    </div>
    <div>
      <label style="display: block; font-size: 0.6875rem; font-weight: 500; color: var(--text-tertiary); margin-bottom: 0.25rem;">Status</label>
      <%= f.select :status, options_for_select([["All Statuses", ""], ["Open", "open"], ["In Progress", "in_progress"], ["Resolved", "resolved"]], params[:status]), {}, class: "filter-select" %>
    </div>
    <div>
      <label style="display: block; font-size: 0.6875rem; font-weight: 500; color: var(--text-tertiary); margin-bottom: 0.25rem;">Channel</label>
      <%= f.select :channel, options_for_select([["All Channels", ""], ["Call", "call"], ["Email", "email"], ["Chat", "chat"]], params[:channel]), {}, class: "filter-select" %>
    </div>
    <div>
      <label style="display: block; font-size: 0.6875rem; font-weight: 500; color: var(--text-tertiary); margin-bottom: 0.25rem;">Priority</label>
      <%= f.select :priority, options_for_select([["All Priorities", ""], ["High", "high"], ["Medium", "medium"], ["Low", "low"]], params[:priority]), {}, class: "filter-select" %>
    </div>
    <div style="flex: 1;">
      <label style="display: block; font-size: 0.6875rem; font-weight: 500; color: var(--text-tertiary); margin-bottom: 0.25rem;">Search</label>
      <%= f.text_field :search, value: params[:search], placeholder: "Search by subject or agent...", class: "filter-input", style: "width: 100%;" %>
    </div>
    <div>
      <%= f.submit "Filter", class: "btn-primary" %>
    </div>
  <% end %>
</div>

<!-- Conversations List -->
<%= turbo_frame_tag "conversations_list" do %>
  <div class="card" style="overflow: hidden;">
    <% if @vcons.any? %>
      <table class="data-table">
        <thead>
          <tr>
            <th>Subject</th>
            <th>Branch</th>
            <th>Agent</th>
            <th>Status</th>
            <th>Channel</th>
            <th>Priority</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% @vcons.each do |vcon| %>
            <tr style="cursor: pointer;" onclick="window.location='<%= conversation_path(vcon) %>'">
              <td style="font-weight: 500;"><%= channel_label(vcon.channel) %> <%= vcon.subject || "Untitled" %></td>
              <td class="text-secondary"><%= vcon.branch %></td>
              <td class="text-secondary"><%= vcon.agent&.display_name || "—" %></td>
              <td><%= status_badge(vcon.status) %></td>
              <td class="text-secondary"><%= vcon.channel&.humanize %></td>
              <td><%= priority_badge(vcon.priority) %></td>
              <td class="text-secondary"><%= vcon.created_at&.strftime("%b %d, %Y") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div style="padding: 3rem; text-align: center;">
        <p style="font-size: 0.9375rem;" class="text-secondary">No conversations found</p>
        <p style="font-size: 0.75rem; margin-top: 0.25rem;" class="text-tertiary">Try adjusting your filters</p>
      </div>
    <% end %>
  </div>
<% end %>
