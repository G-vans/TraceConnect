<% content_for(:title) { "Conversations — TraceConnect" } %>

<!-- Page Header -->
<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Conversations</h1>
  <p class="mt-1 text-sm text-gray-500">Search and trace any conversation across all branches</p>
</div>

<!-- Filters -->
<div class="mb-6 rounded-lg bg-white shadow p-4" data-controller="filter">
  <%= form_with url: conversations_path, method: :get, class: "flex flex-wrap gap-4 items-end", data: { turbo_frame: "conversations_list" } do |f| %>
    <div>
      <label class="block text-xs font-medium text-gray-500 mb-1">Branch</label>
      <%= f.select :branch, options_for_select([["All Branches", ""], "Nairobi", "Lagos", "New York"], params[:branch]), {}, class: "rounded-md border-gray-300 text-sm shadow-sm focus:border-cyan-500 focus:ring-cyan-500" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-gray-500 mb-1">Status</label>
      <%= f.select :status, options_for_select([["All Statuses", ""], ["Open", "open"], ["In Progress", "in_progress"], ["Resolved", "resolved"]], params[:status]), {}, class: "rounded-md border-gray-300 text-sm shadow-sm focus:border-cyan-500 focus:ring-cyan-500" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-gray-500 mb-1">Channel</label>
      <%= f.select :channel, options_for_select([["All Channels", ""], ["Call", "call"], ["Email", "email"], ["Chat", "chat"]], params[:channel]), {}, class: "rounded-md border-gray-300 text-sm shadow-sm focus:border-cyan-500 focus:ring-cyan-500" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-gray-500 mb-1">Priority</label>
      <%= f.select :priority, options_for_select([["All Priorities", ""], ["High", "high"], ["Medium", "medium"], ["Low", "low"]], params[:priority]), {}, class: "rounded-md border-gray-300 text-sm shadow-sm focus:border-cyan-500 focus:ring-cyan-500" %>
    </div>
    <div class="flex-1">
      <label class="block text-xs font-medium text-gray-500 mb-1">Search</label>
      <%= f.text_field :search, value: params[:search], placeholder: "Search by subject or agent...", class: "w-full rounded-md border-gray-300 text-sm shadow-sm focus:border-cyan-500 focus:ring-cyan-500" %>
    </div>
    <div>
      <%= f.submit "Filter", class: "rounded-md bg-cyan-600 px-4 py-2 text-sm font-medium text-white hover:bg-cyan-700 cursor-pointer" %>
    </div>
  <% end %>
</div>

<!-- Conversations List -->
<%= turbo_frame_tag "conversations_list" do %>
  <div class="overflow-hidden rounded-lg bg-white shadow">
    <% if @vcons.any? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Subject</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Branch</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Agent</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Channel</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Priority</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white">
          <% @vcons.each do |vcon| %>
            <tr class="hover:bg-gray-50 cursor-pointer" onclick="window.location='<%= conversation_path(vcon) %>'">
              <td class="px-4 py-3 text-sm font-medium text-gray-900">
                <%= channel_icon(vcon.channel) %> <%= vcon.subject || "Untitled Conversation" %>
              </td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= vcon.branch %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= vcon.agent&.display_name || "—" %></td>
              <td class="px-4 py-3"><%= status_badge(vcon.status) %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= vcon.channel&.titleize %></td>
              <td class="px-4 py-3"><%= priority_badge(vcon.priority) %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= vcon.created_at&.strftime("%b %d, %Y") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-12 text-center">
        <p class="text-lg text-gray-500">No conversations found</p>
        <p class="text-sm text-gray-400 mt-1">Try adjusting your filters</p>
      </div>
    <% end %>
  </div>
<% end %>
