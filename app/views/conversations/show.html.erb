<% content_for(:title) { "#{@vcon.subject} — TraceConnect" } %>

<div style="margin-bottom: 1rem;">
  <%= link_to "← Back to Conversations", conversations_path, style: "font-size: 0.8125rem; color: var(--text-secondary); text-decoration: none;" %>
</div>

<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1rem;">
  <!-- Main Content -->
  <div style="display: flex; flex-direction: column; gap: 1rem;">
    <!-- Conversation Header -->
    <div class="card-padded">
      <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
        <h1 style="font-size: 1.125rem; font-weight: 600;">
          <%= channel_label(@vcon.channel) %> <%= @vcon.subject || "Untitled Conversation" %>
        </h1>
        <%= status_badge(@vcon.status) %>
      </div>
      <div style="display: flex; gap: 1rem; font-size: 0.75rem;" class="text-secondary">
        <span>Branch: <strong class="text-primary"><%= @vcon.branch %></strong></span>
        <span>Channel: <strong class="text-primary"><%= @vcon.channel&.humanize %></strong></span>
        <span>Priority: <%= priority_badge(@vcon.priority) %></span>
        <span>Created: <strong class="text-primary"><%= @vcon.created_at&.strftime("%b %d, %Y %H:%M") %></strong></span>
      </div>
    </div>

    <!-- Conversation Trail -->
    <div class="card-padded">
      <h2 class="section-title">Conversation Trail</h2>
      <% if @vcon.dialogs.any? %>
        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
          <% @vcon.dialogs.chronological.each do |dialog| %>
            <% speaker = dialog.speaker(@vcon) %>
            <% is_agent = speaker&.role == "agent" || speaker&.role == "supervisor" %>
            <div style="display: flex; <%= is_agent ? 'justify-content: flex-end;' : 'justify-content: flex-start;' %>">
              <div class="<%= is_agent ? 'dialog-bubble dialog-bubble-agent' : 'dialog-bubble' %>">
                <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.25rem;">
                  <span style="font-size: 0.6875rem; font-weight: 600;">
                    <%= speaker&.display_name || "Unknown" %>
                    <% if speaker&.role %>
                      <span class="text-tertiary">(<%= speaker.role.humanize %>)</span>
                    <% end %>
                  </span>
                  <span class="text-tertiary" style="font-size: 0.6875rem;"><%= dialog.start_time&.strftime("%H:%M") %></span>
                </div>
                <p style="font-size: 0.8125rem;"><%= dialog.body %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-secondary" style="font-size: 0.8125rem;">No dialog entries recorded</p>
      <% end %>
    </div>

    <!-- AI Summary -->
    <% if @vcon.summary.present? %>
      <div class="card-padded">
        <h2 class="section-title">AI Summary</h2>
        <p style="font-size: 0.8125rem;" class="text-secondary"><%= @vcon.summary %></p>
      </div>
    <% end %>
  </div>

  <!-- Sidebar -->
  <div style="display: flex; flex-direction: column; gap: 1rem;">
    <!-- Participants -->
    <div class="card-padded">
      <h2 class="section-title">Participants</h2>
      <div style="display: flex; flex-direction: column; gap: 0.75rem;">
        <% @vcon.parties.order(:party_index).each do |party| %>
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <div style="width: 2rem; height: 2rem; border-radius: 9999px; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 600; background: var(--bg-muted); color: var(--text-secondary);">
              <%= party.display_name.first.upcase %>
            </div>
            <div>
              <p style="font-size: 0.8125rem; font-weight: 500;"><%= party.display_name %></p>
              <p class="text-tertiary" style="font-size: 0.6875rem;"><%= party.role&.humanize %> · <%= party.mailto || party.tel %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Consent Info -->
    <% consent = @vcon.consent_data %>
    <% if consent.any? %>
      <div class="card-padded">
        <h2 class="section-title">Consent</h2>
        <div style="display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.8125rem;">
          <div style="display: flex; justify-content: space-between;">
            <span class="text-secondary">Status</span>
            <span style="font-weight: 500; color: <%= consent['consent_given'] ? 'var(--status-green)' : 'var(--status-red)' %>;">
              <%= consent['consent_given'] ? 'Given' : 'Not Given' %>
            </span>
          </div>
          <% if consent['consent_law'] %>
            <div style="display: flex; justify-content: space-between;">
              <span class="text-secondary">Law</span>
              <span style="font-weight: 500;"><%= consent['consent_law'] %></span>
            </div>
          <% end %>
          <% if consent['consent_purpose'] %>
            <div style="display: flex; justify-content: space-between;">
              <span class="text-secondary">Purpose</span>
              <span style="font-weight: 500;"><%= consent['consent_purpose'] %></span>
            </div>
          <% end %>
          <% if consent['consent_granted_date'] %>
            <div style="display: flex; justify-content: space-between;">
              <span class="text-secondary">Granted</span>
              <span style="font-weight: 500;"><%= consent['consent_granted_date'] %></span>
            </div>
          <% end %>
          <% if consent['consent_expiry_date'] %>
            <% expired = Date.parse(consent['consent_expiry_date']) < Date.today rescue false %>
            <div style="display: flex; justify-content: space-between;">
              <span class="text-secondary">Expires</span>
              <span style="font-weight: 500; color: <%= expired ? 'var(--status-red)' : 'var(--text-primary)' %>;">
                <%= consent['consent_expiry_date'] %> <%= '(EXPIRED)' if expired %>
              </span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Sentiment -->
    <% sentiment = @vcon.sentiment %>
    <% if sentiment.is_a?(Hash) %>
      <div class="card-padded" style="text-align: center;">
        <h2 class="section-title" style="text-align: left;">Sentiment</h2>
        <div style="font-size: 1.25rem; font-weight: 600; color: <%= sentiment['label'] == 'positive' ? 'var(--status-green)' : sentiment['label'] == 'negative' ? 'var(--status-red)' : 'var(--status-yellow)' %>;">
          <%= sentiment['label']&.humanize %>
        </div>
        <% if sentiment['score'] %>
          <div class="text-secondary" style="font-size: 0.75rem;">Score: <%= sentiment['score'] %></div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
