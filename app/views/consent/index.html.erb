<% content_for(:title) { "Consent Dashboard — TraceConnect" } %>

<!-- Page Header -->
<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Consent Dashboard</h1>
  <p class="mt-1 text-sm text-gray-500">Verify each branch handles consent correctly per their country's data protection law</p>
</div>

<!-- Alerts -->
<% if @expiring_soon.any? || @expired.any? %>
  <div class="mb-6 space-y-3">
    <% if @expired.any? %>
      <div class="rounded-lg bg-red-50 border border-red-200 p-4">
        <div class="flex items-center">
          <span class="text-xl mr-2">🚫</span>
          <div>
            <h3 class="text-sm font-semibold text-red-800">
              <%= @expired.size %> conversation<%= @expired.size == 1 ? '' : 's' %> with EXPIRED consent
            </h3>
            <p class="text-xs text-red-600 mt-1">AI access blocked — consent must be renewed before analysis</p>
          </div>
        </div>
      </div>
    <% end %>
    <% if @expiring_soon.any? %>
      <div class="rounded-lg bg-yellow-50 border border-yellow-200 p-4">
        <div class="flex items-center">
          <span class="text-xl mr-2">⚠️</span>
          <div>
            <h3 class="text-sm font-semibold text-yellow-800">
              <%= @expiring_soon.size %> conversation<%= @expiring_soon.size == 1 ? '' : 's' %> with consent expiring within 7 days
            </h3>
            <p class="text-xs text-yellow-600 mt-1">Contact customers to renew consent before it expires</p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<!-- Branch Consent Overview -->
<div class="grid grid-cols-1 gap-6 lg:grid-cols-3 mb-8">
  <% @branches.each do |branch| %>
    <div class="overflow-hidden rounded-lg bg-white shadow">
      <div class="px-4 py-5 sm:p-6">
        <div class="flex items-center justify-between mb-4">
          <div>
            <h3 class="text-lg font-semibold text-gray-900"><%= branch[:name] %></h3>
            <p class="text-sm text-gray-500"><%= branch[:country] %></p>
          </div>
          <span class="inline-flex items-center rounded-md bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-700">
            <%= branch[:law] %>
          </span>
        </div>

        <!-- Consent Breakdown -->
        <div class="space-y-3">
          <div class="flex items-center justify-between">
            <span class="flex items-center text-sm text-gray-600">
              <span class="mr-2 h-3 w-3 rounded-full bg-green-500"></span>
              Valid Consent
            </span>
            <span class="text-sm font-semibold text-gray-900"><%= branch[:valid_consent] %></span>
          </div>
          <div class="flex items-center justify-between">
            <span class="flex items-center text-sm text-gray-600">
              <span class="mr-2 h-3 w-3 rounded-full bg-yellow-500"></span>
              Expiring Soon
            </span>
            <span class="text-sm font-semibold text-gray-900"><%= branch[:expiring_soon] %></span>
          </div>
          <div class="flex items-center justify-between">
            <span class="flex items-center text-sm text-gray-600">
              <span class="mr-2 h-3 w-3 rounded-full bg-red-500"></span>
              Expired
            </span>
            <span class="text-sm font-semibold text-gray-900"><%= branch[:expired] %></span>
          </div>
          <div class="flex items-center justify-between">
            <span class="flex items-center text-sm text-gray-600">
              <span class="mr-2 h-3 w-3 rounded-full bg-gray-400"></span>
              No Consent
            </span>
            <span class="text-sm font-semibold text-gray-900"><%= branch[:no_consent] %></span>
          </div>
        </div>

        <!-- Progress Bar -->
        <% valid_pct = branch[:total] > 0 ? (branch[:valid_consent].to_f / branch[:total] * 100).round : 0 %>
        <div class="mt-4">
          <div class="flex justify-between text-xs text-gray-500 mb-1">
            <span>Compliance</span>
            <span><%= valid_pct %>%</span>
          </div>
          <div class="h-2 w-full rounded-full bg-gray-200">
            <div class="h-2 rounded-full <%= valid_pct == 100 ? 'bg-green-500' : valid_pct >= 70 ? 'bg-yellow-500' : 'bg-red-500' %>"
                 style="width: <%= valid_pct %>%"></div>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<!-- Expired Conversations Table -->
<% if @expired.any? %>
  <div class="rounded-lg bg-white shadow mb-6">
    <div class="px-4 py-5 sm:p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">🚫 Expired Consent — AI Access Blocked</h2>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Subject</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Branch</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Law</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Expired On</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @expired.each do |vcon| %>
            <% consent = vcon.consent_data %>
            <tr class="bg-red-50 opacity-60">
              <td class="px-4 py-3 text-sm text-gray-500 line-through"><%= vcon.subject %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= vcon.branch %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= consent['consent_law'] %></td>
              <td class="px-4 py-3 text-sm text-red-600 font-medium"><%= consent['consent_expiry_date'] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>
