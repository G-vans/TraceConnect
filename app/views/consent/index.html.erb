<% content_for(:title) { "Consent Dashboard — TraceConnect" } %>

<div style="margin-bottom: 1.5rem;">
  <h1 style="font-size: 1.25rem; font-weight: 600;">Consent Dashboard</h1>
  <p class="section-subtitle" style="margin-top: 0.25rem;">Verify each branch handles consent correctly per their country's data protection law</p>
</div>

<!-- Alerts -->
<% if @expiring_soon.any? || @expired.any? %>
  <div style="display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.5rem;">
    <% if @expired.any? %>
      <div class="alert alert-warning">
        <div style="display: flex; align-items: center; gap: 0.5rem;">
          <span>⚠</span>
          <div>
            <div style="font-size: 0.8125rem; font-weight: 600; color: var(--status-red);">
              <%= @expired.size %> conversation<%= @expired.size == 1 ? '' : 's' %> with expired consent
            </div>
            <div class="text-secondary" style="font-size: 0.75rem; margin-top: 0.125rem;">AI access blocked — consent must be renewed before analysis</div>
          </div>
        </div>
      </div>
    <% end %>
    <% if @expiring_soon.any? %>
      <div class="alert alert-caution">
        <div style="display: flex; align-items: center; gap: 0.5rem;">
          <span>⏳</span>
          <div>
            <div style="font-size: 0.8125rem; font-weight: 600; color: var(--status-yellow);">
              <%= @expiring_soon.size %> conversation<%= @expiring_soon.size == 1 ? '' : 's' %> with consent expiring within 7 days
            </div>
            <div class="text-secondary" style="font-size: 0.75rem; margin-top: 0.125rem;">Contact customers to renew consent before it expires</div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<!-- Branch Consent Cards -->
<div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1.5rem;">
  <% @branches.each do |branch| %>
    <div class="card-padded">
      <div style="display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 1rem;">
        <div>
          <h3 style="font-size: 0.9375rem; font-weight: 600;"><%= branch[:name] %></h3>
          <p class="text-secondary" style="font-size: 0.75rem;"><%= branch[:country] %></p>
        </div>
        <span class="badge badge-neutral"><%= branch[:law] %></span>
      </div>

      <div style="display: flex; flex-direction: column; gap: 0.625rem;">
        <div style="display: flex; align-items: center; justify-content: space-between;">
          <span style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.8125rem;" class="text-secondary">
            <span class="indicator-dot dot-green"></span> Valid Consent
          </span>
          <span style="font-size: 0.8125rem; font-weight: 600;"><%= branch[:valid_consent] %></span>
        </div>
        <div style="display: flex; align-items: center; justify-content: space-between;">
          <span style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.8125rem;" class="text-secondary">
            <span class="indicator-dot dot-yellow"></span> Expiring Soon
          </span>
          <span style="font-size: 0.8125rem; font-weight: 600;"><%= branch[:expiring_soon] %></span>
        </div>
        <div style="display: flex; align-items: center; justify-content: space-between;">
          <span style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.8125rem;" class="text-secondary">
            <span class="indicator-dot dot-red"></span> Expired
          </span>
          <span style="font-size: 0.8125rem; font-weight: 600;"><%= branch[:expired] %></span>
        </div>
        <div style="display: flex; align-items: center; justify-content: space-between;">
          <span style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.8125rem;" class="text-secondary">
            <span class="indicator-dot dot-gray"></span> No Consent
          </span>
          <span style="font-size: 0.8125rem; font-weight: 600;"><%= branch[:no_consent] %></span>
        </div>
      </div>

      <!-- Progress Bar -->
      <% valid_pct = branch[:total] > 0 ? (branch[:valid_consent].to_f / branch[:total] * 100).round : 0 %>
      <div style="margin-top: 1rem;">
        <div style="display: flex; justify-content: space-between; font-size: 0.6875rem; margin-bottom: 0.25rem;" class="text-tertiary">
          <span>Compliance</span>
          <span><%= valid_pct %>%</span>
        </div>
        <div class="progress-track">
          <div class="progress-fill <%= valid_pct == 100 ? 'progress-green' : valid_pct >= 70 ? 'progress-yellow' : 'progress-red' %>"
               style="width: <%= valid_pct %>%;"></div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<!-- Expired Conversations Table -->
<% if @expired.any? %>
  <div class="card-padded">
    <h2 class="section-title">Expired Consent — AI Access Blocked</h2>
    <table class="data-table">
      <thead>
        <tr>
          <th>Subject</th>
          <th>Branch</th>
          <th>Law</th>
          <th>Expired On</th>
        </tr>
      </thead>
      <tbody>
        <% @expired.each do |vcon| %>
          <% consent = vcon.consent_data %>
          <tr class="muted-row">
            <td style="text-decoration: line-through;"><%= vcon.subject %></td>
            <td><%= vcon.branch %></td>
            <td><%= consent['consent_law'] %></td>
            <td class="text-red"><%= consent['consent_expiry_date'] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
