<% content_for(:title) { "Performance Board — TraceConnect" } %>

<div style="margin-bottom: 1.5rem;">
  <h1 style="font-size: 1.25rem; font-weight: 600;">Performance Board</h1>
  <p class="section-subtitle" style="margin-top: 0.25rem;">Compare branches, identify top performers, connect what works to where it's needed</p>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
  <!-- Resolution Times -->
  <div class="card-padded">
    <h2 class="section-title">Avg Resolution Time by Branch</h2>
    <%= bar_chart @resolution_by_branch, suffix: "h", colors: ["#26251e"], library: { plugins: { legend: { display: false } } } %>
  </div>

  <!-- Sentiment -->
  <div class="card-padded">
    <h2 class="section-title">Average Sentiment Score by Branch</h2>
    <%= bar_chart @sentiment_by_branch, colors: ["#2d8a4e"], library: { plugins: { legend: { display: false } } } %>
  </div>
</div>

<!-- Top Agents -->
<div class="card-padded" style="margin-bottom: 1rem;">
  <h2 class="section-title">Top Agents This Week</h2>
  <% if @top_agents.any? %>
    <table class="data-table">
      <thead>
        <tr>
          <th>Rank</th>
          <th>Agent</th>
          <th>Branch</th>
          <th>Issues Resolved</th>
        </tr>
      </thead>
      <tbody>
        <% @top_agents.each_with_index do |agent, i| %>
          <tr>
            <td style="font-weight: 600;">
              <%= i == 0 ? '1st' : i == 1 ? '2nd' : i == 2 ? '3rd' : "#{i + 1}th" %>
            </td>
            <td style="font-weight: 500;"><%= agent[:name] %></td>
            <td class="text-secondary"><%= agent[:branch] %></td>
            <td><span class="badge badge-resolved"><%= agent[:resolved] %> resolved</span></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-secondary" style="font-size: 0.8125rem;">No resolved issues yet this week</p>
  <% end %>
</div>

<!-- Issue Categories -->
<div class="card-padded">
  <h2 class="section-title">Issue Categories by Branch</h2>
  <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;">
    <% @categories_by_branch.each do |branch, categories| %>
      <div>
        <h3 style="font-size: 0.8125rem; font-weight: 600; margin-bottom: 0.75rem;"><%= branch %></h3>
        <% if categories.any? %>
          <% categories.sort_by { |_cat, count| -count }.each do |category, count| %>
            <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.25rem 0;">
              <span class="text-secondary" style="font-size: 0.8125rem;"><%= category&.humanize %></span>
              <span class="badge badge-neutral"><%= count %></span>
            </div>
          <% end %>
        <% else %>
          <p class="text-tertiary" style="font-size: 0.8125rem;">No data</p>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
