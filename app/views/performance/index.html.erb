<% content_for(:title) { "Performance Board — TraceConnect" } %>

<!-- Page Header -->
<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Performance Board</h1>
  <p class="mt-1 text-sm text-gray-500">Compare branches, identify top performers, connect what works to where it's needed</p>
</div>

<div class="grid grid-cols-1 gap-6 lg:grid-cols-2 mb-8">
  <!-- Resolution Times by Branch -->
  <div class="rounded-lg bg-white shadow p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Avg Resolution Time by Branch</h2>
    <%= bar_chart @resolution_by_branch, suffix: "h", colors: ["#0891b2"], library: { plugins: { legend: { display: false } } } %>
  </div>

  <!-- Sentiment by Branch -->
  <div class="rounded-lg bg-white shadow p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Average Sentiment Score by Branch</h2>
    <%= bar_chart @sentiment_by_branch, colors: ["#059669"], library: { plugins: { legend: { display: false } } } %>
  </div>
</div>

<!-- Top Agents -->
<div class="rounded-lg bg-white shadow p-6 mb-6">
  <h2 class="text-lg font-semibold text-gray-900 mb-4">🏆 Top Agents This Week</h2>
  <% if @top_agents.any? %>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Rank</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Agent</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Branch</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Issues Resolved</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @top_agents.each_with_index do |agent, i| %>
          <tr class="<%= i == 0 ? 'bg-yellow-50' : '' %>">
            <td class="px-4 py-3 text-sm font-bold text-gray-900">
              <%= i == 0 ? '🥇' : i == 1 ? '🥈' : i == 2 ? '🥉' : "##{i + 1}" %>
            </td>
            <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= agent[:name] %></td>
            <td class="px-4 py-3 text-sm text-gray-500"><%= agent[:branch] %></td>
            <td class="px-4 py-3">
              <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800">
                <%= agent[:resolved] %> resolved
              </span>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-sm text-gray-500">No resolved issues yet this week</p>
  <% end %>
</div>

<!-- Issue Categories by Branch -->
<div class="rounded-lg bg-white shadow p-6">
  <h2 class="text-lg font-semibold text-gray-900 mb-4">Issue Categories by Branch</h2>
  <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
    <% @categories_by_branch.each do |branch, categories| %>
      <div>
        <h3 class="text-sm font-semibold text-gray-700 mb-3"><%= branch %></h3>
        <% if categories.any? %>
          <% categories.sort_by { |_cat, count| -count }.each do |category, count| %>
            <div class="flex items-center justify-between py-1">
              <span class="text-sm text-gray-600"><%= category&.titleize %></span>
              <span class="inline-flex items-center rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-700">
                <%= count %>
              </span>
            </div>
          <% end %>
        <% else %>
          <p class="text-sm text-gray-400">No data</p>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
